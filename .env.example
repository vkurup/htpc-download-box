# Your timezone, https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# UNIX PUID and PGID, find with: id $USER
PUID=1000
PGID=1000

# Where media and config data are stored on the host
MEDIA_ROOT=/mnt/storage/data
CONFIG_ROOT=/mnt/storage/config

# PureVPN OpenVPN credentials
OPENVPN_USER=
OPENVPN_PASSWORD=

# How often gluetun updates the VPN server list (e.g. 24h)
UPDATER_PERIOD=24h

# Cloudflare API token for Traefik Let's Encrypt DNS challenge
# Create at: Cloudflare → My Profile → API Tokens → Edit zone DNS (scoped to kurup.net)
CF_DNS_API_TOKEN=

# Homepage API keys (Settings → General in each service)
HOMEPAGE_VAR_JELLYFIN_API_KEY=
HOMEPAGE_VAR_SONARR_API_KEY=
HOMEPAGE_VAR_RADARR_API_KEY=
HOMEPAGE_VAR_PROWLARR_API_KEY=
HOMEPAGE_VAR_SABNZBD_API_KEY=
